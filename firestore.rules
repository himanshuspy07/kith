rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Kith Chat Application Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRoomMember(chatRoomId) {
      return isSignedIn() && get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.members[request.auth.uid] == true;
    }

    function isRoomMemberData(data) {
      return isSignedIn() && data != null && data.members != null && data.members[request.auth.uid] == true;
    }

    function isRoomAdmin(chatRoomId) {
      return isSignedIn() && get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.createdBy == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /chatRooms/{chatRoomId} {
      allow list: if isSignedIn();
      allow get: if isRoomMemberData(resource.data);
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] == true;
      allow update, delete: if isRoomMemberData(resource.data);

      match /messages/{messageId} {
        allow list, get: if isRoomMember(chatRoomId);
        allow create: if isRoomMember(chatRoomId) && request.resource.data.senderId == request.auth.uid;
        allow update: if isRoomMember(chatRoomId) && (
          resource.data.senderId == request.auth.uid ||
          isRoomAdmin(chatRoomId) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'reactions'])
        );
        allow delete: if isRoomMember(chatRoomId) && (resource.data.senderId == request.auth.uid || isRoomAdmin(chatRoomId));
      }
    }
  }
}
