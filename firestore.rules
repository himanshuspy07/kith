rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Kith Chat Application Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRoomMember(data) {
      return isSignedIn() && data != null && data.members != null && data.members[request.auth.uid] == true;
    }

    function isMessageCollaborator(data) {
      return isSignedIn() && data != null && data.chatRoomMembers != null && data.chatRoomMembers[request.auth.uid] == true;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    match /chatRooms/{chatRoomId} {
      // Allow list and get if user is in the members map
      allow list, get: if isRoomMember(resource.data);
      
      // Allow creation if the user is including themselves as a member
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] == true;
      
      // Allow update/delete if already a member
      allow update, delete: if isRoomMember(resource.data);

      match /messages/{messageId} {
        allow get, list: if isMessageCollaborator(resource.data);
        allow create: if isSignedIn() 
          && request.resource.data.chatRoomMembers[request.auth.uid] == true 
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isMessageCollaborator(resource.data) 
          && resource.data.senderId == request.auth.uid;
      }
    }
  }
}