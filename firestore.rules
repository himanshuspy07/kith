rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Kith Chat Application Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRoomMember(chatRoomId) {
      return isSignedIn() && get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.members[request.auth.uid] == true;
    }

    function isRoomMemberData(data) {
      return isSignedIn() && data != null && data.members != null && data.members[request.auth.uid] == true;
    }

    function isRoomAdmin(chatRoomId) {
      return isSignedIn() && get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.createdBy == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /chatRooms/{chatRoomId} {
      // Allow list and get if user is in the members map
      allow list: if isSignedIn(); // Queries are filtered by application logic
      allow get: if isRoomMemberData(resource.data);
      
      // Allow creation if the user is including themselves as a member
      allow create: if isSignedIn() && request.resource.data.members[request.auth.uid] == true;
      
      // Allow update/delete if already a member
      allow update, delete: if isRoomMemberData(resource.data);

      match /messages/{messageId} {
        // Allow access if the user is a member of the parent room
        allow list, get: if isRoomMember(chatRoomId);
        
        // Allow creation if member and sender is self
        allow create: if isRoomMember(chatRoomId) && request.resource.data.senderId == request.auth.uid;
          
        // Allow update if member and (sender OR room admin OR only updating readBy/reactions)
        allow update: if isRoomMember(chatRoomId) && (
          resource.data.senderId == request.auth.uid ||
          isRoomAdmin(chatRoomId) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'reactions'])
        );
        
        // Only sender or admin can delete their own message
        allow delete: if isRoomMember(chatRoomId) && (resource.data.senderId == request.auth.uid || isRoomAdmin(chatRoomId));
      }
    }

    // --- Call Signaling Rules ---

    match /calls/{callId} {
      // Allow listing calls (queries are filtered by receiverId in app)
      allow list: if isSignedIn();
      
      // Allow get/update if the user is the caller or receiver
      allow get, update: if isSignedIn() && (
        resource.data.callerId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      
      // Allow creation if user is the caller
      allow create: if isSignedIn() && request.resource.data.callerId == request.auth.uid;
      
      // Allow deletion by the caller
      allow delete: if isSignedIn() && resource.data.callerId == request.auth.uid;

      // ICE Candidate signaling subcollections
      match /callerCandidates/{id} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid ||
          get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid
        );
      }
      
      match /receiverCandidates/{id} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid ||
          get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid
        );
      }
    }
  }
}
